<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Client.Avalonia.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uic="using:Lib.Avalonia.Controls"
             xmlns:shapes="using:Client.Avalonia.Views.Geometry.Shapes" 
             x:DataType="local:GeometryViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Client.Avalonia.Views.GeometryView" >

    <Design.DataContext>
        <local:GeometryViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="auto,*">

    <local:GeometryCreateMenuView
        Grid.Row="0"
        DataContext="{Binding GeometryCreateMenuViewModel}"/>

        <local:DisplayView 
        Grid.Row="1"
        DataContext="{Binding DisplayViewModel}"/> 
    </Grid> 
</UserControl>
