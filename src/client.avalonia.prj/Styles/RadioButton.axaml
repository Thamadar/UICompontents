<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tab="using:Client.Avalonia.Views"
        xmlns:uiconverters="using:Lib.Avalonia.Converters">
  <Design.PreviewWith>
    <Border Padding="20">
        <StackPanel Orientation="Vertical"
        Background="{StaticResource PrimaryBlue}">
            <RadioButton 
            GroupName="Tab"
            Classes="tab"
            Content="Graphs"/>
            <RadioButton Classes="tab"
            GroupName="Tab"
            Content="Geometry"/>
    <RadioButton Classes="tab"
            Content="Граф. редактор"
            GroupName="Tab"/>
        </StackPanel>
    </Border>
  </Design.PreviewWith>

  <Styles.Resources> 
    <uiconverters:SwitchConverter
    x:Key="TabCategoryIconConverter">
        <uiconverters:Case
        Key="{x:Static tab:TabCategoryEnum.Graphs}"
        Value="{StaticResource GraphicIcon}" />
    <uiconverters:Case
        Key="{x:Static tab:TabCategoryEnum.GraphicEditor}"
        Value="{StaticResource SphereIcon}" />
        </uiconverters:SwitchConverter>
  </Styles.Resources>

    <Style Selector="RadioButton.tab">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding"    Value="0"/>
        <Setter Property="Background" Value="transparent" />
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Margin"     Value="0 0 0 0" />
        <Setter Property="Height" Value="90" />
        <Setter Property="Width" Value="80" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius"     Value="0" /> 
        <Setter Property="BorderThickness"     Value="0" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid
                Name="PART_Container"
                RowDefinitions="50,*"
                Background="{TemplateBinding Background}"
                x:DataType="tab:ITabMenu">
                    
                    <ContentControl
                    Margin="-3,3,0,0"
                    Template="{Binding TabCategory,
                                       Converter={StaticResource TabCategoryIconConverter}}"
                    Width="32" Height="32" VerticalAlignment="Center" VerticalContentAlignment="Center"
                    HorizontalAlignment="Center"
                    Foreground="{TemplateBinding Foreground}"/>

                      <ContentPresenter
                      Grid.Row="1"
                      Name="PART_ContentPresenter"
                      Height="{TemplateBinding Height}"
                      Foreground="{TemplateBinding Foreground}"
                      Margin="{TemplateBinding Margin}" 
                      Padding="{TemplateBinding Padding}"
                      TextAlignment="Center"
                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                   
                      HorizontalAlignment="Center" 
                      Content="{TemplateBinding Content}"
                      TextWrapping="Wrap"
                      Background="Transparent"
                      BorderBrush="Transparent"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="{TemplateBinding CornerRadius}" />
                </Grid> 
            </ControlTemplate>
        </Setter>

        <Style Selector="^ > TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

        <Style Selector="^:checked"> 
            <Setter Property="Background" Value="#025d9b"/>
            <Setter Property="BorderBrush" Value="#025d9b"/>
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="White" />
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="White" />
            </Style>
        </Style>

        <Style Selector="^:pointerover:not(:checked)">
            <Setter Property="Background" Value="#5fc6f1"/>
            <Setter Property="BorderBrush" Value="#5fc6f1"/>

            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="White" />
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="White" />
            </Style>
    </Style> 
    </Style>
</Styles>
