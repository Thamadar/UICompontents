<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:Client.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:shapes="clr-namespace:Client.WPF.Views.Geometry.Shapes"
    xmlns:uic="clr-namespace:Lib.WPF.Controls;assembly=lib.wpf" xmlns:uiconv="clr-namespace:Lib.WPF.Converters;assembly=lib.wpf"
    d:DesignHeight="150" d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Client.WPF.Views.GeometryCreateMenuView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Background="{StaticResource PrimaryBlue}">
            <StackPanel
                Margin="8,4,8,0"
                Orientation="Horizontal">

                <!-- TO DO: впихнуть иконки. -->
                <RadioButton
                    Content="Прямоугольник"
                    GroupName="Shapes"
                    IsChecked="{Binding SelectedShapeCreate, Converter={x:Static uiconv:EnumToBooleanConverter.Instance}, ConverterParameter={x:Static local:ShapeCreateEnum.Rect}, Mode=TwoWay}"
                    Style="{StaticResource RadioButtonMenuStyle}" />
                <RadioButton
                    Margin="4,0,0,0"
                    Content="Окружность"
                    GroupName="Shapes"
                    IsChecked="{Binding SelectedShapeCreate, Converter={x:Static uiconv:EnumToBooleanConverter.Instance}, ConverterParameter={x:Static local:ShapeCreateEnum.Circle}, Mode=TwoWay}"
                    Style="{StaticResource RadioButtonMenuStyle}" />
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="1">
            <uic:ViewLocatorControl
                Grid.Column="1"
                Margin="16,0"
                DataContext="{Binding CurrentShapeCreaterVM}" />
        </Grid>

    </Grid>
</UserControl>
