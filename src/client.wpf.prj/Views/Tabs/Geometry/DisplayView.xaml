<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Client.WPF.Bevaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors" xmlns:local="clr-namespace:Client.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:shapes="clr-namespace:Client.WPF.Views.Geometry.Shapes"
    xmlns:uic="clr-namespace:Lib.WPF.Controls;assembly=lib.wpf" xmlns:uiconv="clr-namespace:Lib.WPF.Converters;assembly=lib.wpf"
    d:DesignHeight="450" d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Client.WPF.Views.DisplayView">

    <UserControl.Resources>

        <!-- Шаблоны для геом. фигур -->
        <DataTemplate
            x:Key="CircleTemplate"
            DataType="{x:Type shapes:ICircleItem}">
            <uic:CircleControl
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="{Binding BorderThickness}"
                Fill="{Binding Fill}"
                IsSelected="{Binding IsSelected}"
                Radius="{Binding Radius}" />
        </DataTemplate>

        <DataTemplate
            x:Key="RectTemplate"
            DataType="{x:Type shapes:IRectItem}">
            <uic:RectControl
                Width="{Binding Width}"
                Height="{Binding Height}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="{Binding BorderThickness}"
                Fill="{Binding Fill}"
                IsSelected="{Binding IsSelected}" />
        </DataTemplate>

        <local:ShapeTemplateSelector
            x:Key="ShapeTemplateSelector"
            CircleTemplate="{StaticResource CircleTemplate}"
            RectTemplate="{StaticResource RectTemplate}" />
    </UserControl.Resources>

    <ScrollViewer
        Background="{StaticResource CanvasEmptyBackground}"
        HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <ItemsControl
            ItemsSource="{Binding TotalShapes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas
                        Width="1500" Height="720"
                        Background="Aqua">
                        <i:Interaction.Behaviors>
                            <behaviors:CanvasHitTestBehavior
                            CreateCommand="{Binding CreateShapeCommand}"
                            IsHitTestEnabled="True" />
                        </i:Interaction.Behaviors>
                    </Canvas>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding XCenter}" />
                    <Setter Property="Canvas.Top" Value="{Binding YCenter}" />
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl
                        Content="{Binding}"
                        ContentTemplateSelector="{StaticResource ShapeTemplateSelector}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
