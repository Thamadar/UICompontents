<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:Client.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450" d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Client.WPF.Views.GeometryView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
        </Grid.RowDefinitions>

        <local:GeometryCreateMenuView
            Grid.Row="0"
            DataContext="{Binding GeometryCreateMenuViewModel}" />

        <local:DisplayView
            Grid.Row="1"
            DataContext="{Binding DisplayViewModel}" />
    </Grid>
</UserControl>
